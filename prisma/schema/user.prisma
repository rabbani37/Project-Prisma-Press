model User {
    id            String        @id @default(uuid())
    name          String        @db.VarChar(255)
    email         String        @unique
    password      String
    active_status ACTIVE_STATUS @default(ACTIVE)
    role          ROLE          @default(USER)
    created_at    DateTime      @default(now())
    updated_at    DateTime      @updatedAt

    profile  profile?
    comments Comment[]
    posts    Post[]

    @@map("users")
}
